<div class="flexcol">
	<div class="form-group">
		<label>{{ localize "Name" }}</label>
			<div class="form-fields">
				<input type="text" name="name" placeholder="{{ name }}" autofocus>
			</div>
	</div>

	<div class="form-group">{{log this}}
		<label>{{ localize "Type" }}</label>
		<div class="form-fields">
			<select name="type">
				{{ selectOptions types }}
			</select>
		</div>
	</div>

	{{#if hasFolders}}
		<div class="form-group">
			<label>{{ localize "DOCUMENT.Folder" }}</label>
			<div class="form-fields">
				<select name="folder">
					{{#select folder}}
						<option value=""></option>
						{{#each folders}}
							<option value="{{ id }}">{{ name }}</option>
						{{/each}}
					{{/select}}
				</select>
			</div>
		</div>
	{{/if}}

	{{{ content }}}
</div>
